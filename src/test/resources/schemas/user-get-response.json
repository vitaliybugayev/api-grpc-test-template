{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": { "type": "boolean" },
    "data": {
      "type": "object",
      "required": ["id", "name", "email", "age"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "BANNED"] }
      }
    }
  }
}

